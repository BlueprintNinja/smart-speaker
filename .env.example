# ── Timezone ──────────────────────────────────────────────────────────────────
TZ=America/New_York

# ── Ollama ────────────────────────────────────────────────────────────────────
# Ollama runs natively on the host (not in Docker) so it can access the GPU.
# Docker containers reach the host via host.docker.internal.
OLLAMA_HOST=http://host.docker.internal:11434
OLLAMA_MODEL=llama3

# ── Whisper ───────────────────────────────────────────────────────────────────
WHISPER_MODEL=medium
WHISPER_DEVICE=cuda
WHISPER_DTYPE=float16

# ── Piper TTS ─────────────────────────────────────────────────────────────────
# Place the .onnx + .onnx.json files in backend/models/ and set the path here.
PIPER_MODEL=models/en_US-joe-medium.onnx

# ── Home Assistant ────────────────────────────────────────────────────────────
# URL of your Home Assistant instance.
# In Docker mode, backend reaches HA via host.docker.internal.
HA_URL=http://host.docker.internal:8123
# Long-lived access token from HA: Profile > Security > Long-Lived Access Tokens
HA_TOKEN=paste_your_token_here
